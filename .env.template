# Auto Caption Engine - Environment Configuration

# Groq API Key for Whisper transcription + LLM refinement
# Get your key at: https://console.groq.com/
GROQ_API_KEY=your_groq_api_key_here

# Path to FFmpeg executable
# Windows example: C:\\ffmpeg\\bin\\ffmpeg.exe
# Linux/Mac: /usr/bin/ffmpeg
FFMPEG_PATH=C:\\ffmpeg\\bin\\ffmpeg.exe

# Optional: Whisper model size (tiny, base, small, medium, large)
WHISPER_MODEL=base

# Optional: Server host and port
HOST=0.0.0.0
PORT=8000
